---
import Layout from "../components/Layout.astro";
import Hero from "../components/Hero.astro";
import ProofPointStrip from "../components/ProofPointStrip.astro";
import ModuleGrid from "../components/ModuleGrid.astro";
import GlobalCTA from "../components/GlobalCTA.astro";
import FAQAccordion from "../components/FAQAccordion.astro";
import modules from "../data/modules.json";
import programFacts from "../data/programFacts.json";
import faqs from "../data/faqs.json";

const previewFaqs = faqs.slice(0, 3);
---

<Layout title="CSPB Info Session Dashboard" active="dashboard">
  <div class="space-y-12">
    <Hero />

    <section class="glass-card rounded-[2rem] p-6 shadow-sm lg:p-8">
      <div class="mb-5 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="text-sm font-black uppercase tracking-[0.2em] text-[#8b6f24]">At a glance</p>
          <h2 class="mt-2 text-3xl font-black text-neutral-950">Program highlights</h2>
        </div>
        <p class="max-w-2xl text-sm leading-6 text-neutral-600">
          These proof points come from the current info-session deck and are rendered from controlled content.
        </p>
      </div>
      <ProofPointStrip facts={programFacts.facts} />
    </section>

    <section>
      <div class="mb-6">
        <p class="text-sm font-black uppercase tracking-[0.2em] text-[#8b6f24]">Choose your path</p>
        <h2 class="mt-2 text-4xl font-black tracking-tight text-neutral-950">Explore the modules</h2>
        <p class="mt-3 max-w-3xl text-lg leading-8 text-neutral-600">
          Move through the modules in order or jump directly to the questions most relevant to you.
        </p>
      </div>
      <ModuleGrid modules={modules.filter((module) => module.id !== "start-here")} />
    </section>

    <section class="glass-card rounded-[2rem] p-6 shadow-sm lg:p-8">
      <div class="mb-5">
        <p class="text-sm font-black uppercase tracking-[0.2em] text-[#8b6f24]">FAQ preview</p>
        <h2 class="mt-2 text-3xl font-black text-neutral-950">Common questions</h2>
      </div>
      <FAQAccordion faqs={previewFaqs} />
      <p class="mt-5">
        <a class="focus-ring inline-flex rounded-full bg-neutral-950 px-5 py-3 text-sm font-black text-white hover:bg-neutral-800" href="../faq/">View all FAQs →</a>
      </p>
    </section>

    <GlobalCTA />
  </div>
</Layout>
