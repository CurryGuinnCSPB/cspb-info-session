---
import Layout from "../components/Layout.astro";
import Hero from "../components/Hero.astro";
import ProofPointStrip from "../components/ProofPointStrip.astro";
import ModuleGrid from "../components/ModuleGrid.astro";
import GlobalCTA from "../components/GlobalCTA.astro";
import FAQAccordion from "../components/FAQAccordion.astro";
import modules from "../data/modules.json";
import programFacts from "../data/programFacts.json";
import faqs from "../data/faqs.json";

const previewFaqs = faqs.slice(0, 3);
---

<Layout title="CSPB Info Session Dashboard" active="dashboard">
  <div class="stack-lg">
    <Hero />

    <section class="stack">
      <div>
        <p class="kicker">At a glance</p>
        <h2 class="heading-lg mt-2">Program highlights</h2>
      </div>
      <ProofPointStrip facts={programFacts.facts} />
    </section>

    <section class="stack">
      <div>
        <p class="kicker">Choose your path</p>
        <h2 class="heading-lg mt-2">Explore the modules</h2>
        <p class="lede mt-3 max-w-3xl">
          Move through the modules in order or jump directly to the questions most relevant to you.
        </p>
      </div>
      <ModuleGrid modules={modules.filter((module) => module.id !== "start-here")} />
    </section>

    <section class="card card-pad stack">
      <div>
        <p class="kicker">FAQ preview</p>
        <h2 class="heading-lg mt-2">Common questions</h2>
      </div>
      <FAQAccordion faqs={previewFaqs} />
      <p>
        <a class="focus-ring inline-flex rounded-full bg-neutral-950 px-5 py-3 text-sm font-black text-white hover:bg-neutral-800" href="../faq/">View all FAQs →</a>
      </p>
    </section>

    <GlobalCTA />
  </div>
</Layout>
