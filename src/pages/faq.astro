---
import Layout from "../components/Layout.astro";
import FAQAccordion from "../components/FAQAccordion.astro";
import GlobalCTA from "../components/GlobalCTA.astro";
import { resolveLink } from "../utils/resolveLink.js";
import faqs from "../data/faqs.json";
---

<Layout title="CSPB Info Session FAQ" active="faq">
  <section class="space-y-8">
    <div class="rounded-[2rem] bg-white p-8 shadow-sm ring-1 ring-neutral-200">
      <p class="text-sm font-black uppercase tracking-[0.2em] text-yellow-700">Frequently asked questions</p>
      <h1 class="mt-3 text-5xl font-black tracking-tight text-neutral-950">Common questions about CSPB</h1>
      <p class="mt-4 max-w-3xl text-lg leading-8 text-neutral-600">
        This FAQ gives short answers to common questions about the Computer Science Post-Baccalaureate Program (CSPB). Use the links in each answer to move to the relevant module for more detail.
      </p>
    </div>

    <FAQAccordion faqs={faqs} />

    <section class="space-y-4">
      <div>
        <p class="kicker">Explore by topic</p>
        <h2 class="heading-lg mt-2">Go deeper on a specific question</h2>
      </div>

      <section class="grid gap-3 md:grid-cols-2 lg:grid-cols-3">
        <a class="card card-pad hover:border-[#cfb87c]" href={resolveLink("/modules/admissions-requirements/")}>
          <p class="kicker">Admissions</p>
          <h3 class="heading-md mt-2">Requirements, math, and deadlines</h3>
        </a>
        <a class="card card-pad hover:border-[#cfb87c]" href={resolveLink("/modules/transfer-credit/")}>
          <p class="kicker">Transfer credit</p>
          <h3 class="heading-md mt-2">Previous coursework and advising</h3>
        </a>
        <a class="card card-pad hover:border-[#cfb87c]" href={resolveLink("/modules/non-degree-option/")}>
          <p class="kicker">Non-degree</p>
          <h3 class="heading-md mt-2">Selected courses without degree admission</h3>
        </a>
        <a class="card card-pad hover:border-[#cfb87c]" href={resolveLink("/modules/tuition-fees/")}>
          <p class="kicker">Tuition</p>
          <h3 class="heading-md mt-2">Rates, fees, and COF</h3>
        </a>
        <a class="card card-pad hover:border-[#cfb87c]" href={resolveLink("/modules/online-classes/")}>
          <p class="kicker">Online learning</p>
          <h3 class="heading-md mt-2">Course format and tools</h3>
        </a>
        <a class="card card-pad hover:border-[#cfb87c]" href={resolveLink("/modules/apply-next-steps/")}>
          <p class="kicker">Apply</p>
          <h3 class="heading-md mt-2">Choose a path and apply</h3>
        </a>
      </section>
    </section>

    <GlobalCTA />
  </section>
</Layout>
