---
import Layout from "../components/Layout.astro";
import FAQAccordion from "../components/FAQAccordion.astro";
import GlobalCTA from "../components/GlobalCTA.astro";
import { resolveLink } from "../utils/resolveLink.js";
import faqs from "../data/faqs.json";

const topQuestions = faqs.filter((faq) => faq.topQuestion);
---

<Layout title="CSPB Info Session FAQ" active="faq">
  <section class="space-y-8">
    <div class="rounded-[2rem] bg-white p-8 shadow-sm ring-1 ring-neutral-200">
      <p class="text-sm font-black uppercase tracking-[0.2em] text-yellow-700">Frequently asked questions</p>
      <h1 class="mt-3 text-5xl font-black tracking-tight text-neutral-950">Find the answer, then jump to the right page</h1>
      <p class="mt-4 max-w-3xl text-lg leading-8 text-neutral-600">
        This FAQ gives short answers to common questions about CSPB. Use the links in each answer to move to the relevant module for more detail.
      </p>
    </div>

    <section class="rounded-[2rem] border border-neutral-200 bg-neutral-50 p-6">
      <p class="text-sm font-black uppercase tracking-[0.2em] text-yellow-700">Top questions</p>
      <div class="mt-4 grid gap-3 md:grid-cols-2">
        {topQuestions.map((faq) => (
          <a
            class="rounded-[1.25rem] border border-neutral-200 bg-white p-4 text-sm font-black leading-6 text-neutral-900 shadow-sm hover:border-[#cfb87c]"
            href={`#${faq.id}`}
          >
            {faq.question}
          </a>
        ))}
      </div>
    </section>

    <section class="grid gap-3 md:grid-cols-2 lg:grid-cols-3">
      <a class="card card-pad hover:border-[#cfb87c]" href={resolveLink("/modules/admissions-requirements/")}>
        <p class="kicker">Admissions</p>
        <h2 class="heading-md mt-2">Requirements, math, and deadlines</h2>
      </a>
      <a class="card card-pad hover:border-[#cfb87c]" href={resolveLink("/modules/transfer-credit/")}>
        <p class="kicker">Transfer credit</p>
        <h2 class="heading-md mt-2">Previous coursework and advising</h2>
      </a>
      <a class="card card-pad hover:border-[#cfb87c]" href={resolveLink("/modules/non-degree-option/")}>
        <p class="kicker">Non-degree</p>
        <h2 class="heading-md mt-2">Selected courses without degree admission</h2>
      </a>
      <a class="card card-pad hover:border-[#cfb87c]" href={resolveLink("/modules/tuition-fees/")}>
        <p class="kicker">Tuition</p>
        <h2 class="heading-md mt-2">Rates, fees, and COF</h2>
      </a>
      <a class="card card-pad hover:border-[#cfb87c]" href={resolveLink("/modules/online-classes/")}>
        <p class="kicker">Online learning</p>
        <h2 class="heading-md mt-2">Course format and tools</h2>
      </a>
      <a class="card card-pad hover:border-[#cfb87c]" href={resolveLink("/modules/apply-next-steps/")}>
        <p class="kicker">Apply</p>
        <h2 class="heading-md mt-2">Choose a path and apply</h2>
      </a>
    </section>

    <FAQAccordion faqs={faqs} />

    <GlobalCTA />
  </section>
</Layout>
