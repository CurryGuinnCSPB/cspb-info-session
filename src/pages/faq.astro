---
import Layout from "../components/Layout.astro";
import FAQAccordion from "../components/FAQAccordion.astro";
import GlobalCTA from "../components/GlobalCTA.astro";
import faqs from "../data/faqs.json";
---

<Layout title="CSPB Info Session FAQ" active="faq">
  <section class="space-y-8">
    <div class="rounded-[2rem] bg-neutral-950 p-8 text-white shadow-xl lg:p-10">
      <p class="text-sm font-black uppercase tracking-[0.2em] text-[#cfb87c]">Q&A replacement</p>
      <h1 class="mt-3 text-5xl font-black tracking-tight">Frequently asked questions</h1>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-neutral-300">
        This FAQ is a first-pass replacement for the live Q&A portion of the monthly information session. Answers should be reviewed before production.
      </p>
    </div>

    <FAQAccordion faqs={faqs} />
    <GlobalCTA />
  </section>
</Layout>
