---
import Layout from "../components/Layout.astro";
import CTAButton from "../components/CTAButton.astro";
---

<Layout title="CSPB Self-Guided Info Session" showSidebar={false}>
  <section class="mx-auto grid min-h-[78vh] max-w-7xl items-center gap-10 py-10 lg:grid-cols-[1fr_470px]">
    <div>
      <p class="text-sm font-black uppercase tracking-[0.24em] text-[#8b6f24]">CU Boulder CSPB</p>
      <h1 class="mt-5 max-w-4xl text-5xl font-black tracking-tight text-neutral-950 md:text-7xl">
        A self-guided info session for prospective CSPB students.
      </h1>
      <p class="mt-6 max-w-3xl text-xl leading-9 text-neutral-700">
        Get the core information from the live CSPB information session on your own schedule, with short modules on curriculum, admissions, online learning, tuition, student support, career outcomes, and next steps.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <CTAButton href="/register/" label="Start the info session" />
        <CTAButton href="/dashboard/" label="Continue as returning visitor" variant="secondary" />
      </div>
      <p class="mt-5 max-w-2xl text-sm leading-6 text-neutral-500">
        Mockup note: the production version will use CU Boulder Qualtrics for intake before returning visitors to the dashboard. This prototype collects no real information.
      </p>
    </div>

    <aside class="glass-card rounded-[2rem] p-7 shadow-xl">
      <div class="rounded-[1.5rem] bg-neutral-950 p-6 text-white">
        <p class="text-xs font-black uppercase tracking-[0.2em] text-[#cfb87c]">What this replaces</p>
        <h2 class="mt-3 text-3xl font-black">The live info session, made browsable.</h2>
        <p class="mt-4 text-sm leading-6 text-neutral-300">
          A guided dashboard, short video placeholders, clear written summaries, and CTAs for applying or contacting CSPB.
        </p>
      </div>
      <ul class="mt-6 space-y-3 text-sm leading-6 text-neutral-700">
        <li class="rounded-2xl bg-white p-4 shadow-sm"><strong>Start with the overview</strong>, then jump to the questions you care about.</li>
        <li class="rounded-2xl bg-white p-4 shadow-sm"><strong>Review controlled content</strong> like courses, facts, links, and FAQs.</li>
        <li class="rounded-2xl bg-white p-4 shadow-sm"><strong>Use the mock Qualtrics step</strong> to test the future registration flow.</li>
      </ul>
    </aside>
  </section>
</Layout>
