---
import Layout from "../../components/Layout.astro";
import VideoPlaceholder from "../../components/VideoPlaceholder.astro";
import GlobalCTA from "../../components/GlobalCTA.astro";
import CourseTable from "../../components/CourseTable.astro";
import FAQAccordion from "../../components/FAQAccordion.astro";
import CTAButton from "../../components/CTAButton.astro";
import OutcomePanel from "../../components/OutcomePanel.astro";
import AdmissionsChecklist from "../../components/AdmissionsChecklist.astro";
import SamplePacing from "../../components/SamplePacing.astro";
import ProgramOverviewContent from "../../components/ProgramOverviewContent.astro";
import ApplyNextStepsContent from "../../components/ApplyNextStepsContent.astro";
import { resolveLink } from "../../utils/resolveLink.js";

import modules from "../../data/modules.json";
import courses from "../../data/courses.json";
import faqs from "../../data/faqs.json";
import outcomes from "../../data/outcomes.json";
import admissions from "../../data/admissions.json";

export function getStaticPaths() {
  return modules
    .filter((module) => module.id !== "start-here")
    .map((module) => ({
      params: { slug: module.slug },
      props: { module }
    }));
}

const { module } = Astro.props;
const moduleImageSrc = module.image ? resolveLink(module.image) : "";
const relatedFaqs = faqs.filter((faq) => faq.relatedModules?.includes(module.id));
const isOverview = module.id === "program-overview";
const isCareer = module.id === "career-outcomes";
const isCurriculum = module.id === "curriculum";
const isAdmissions = module.id === "admissions-requirements";
const isApply = module.id === "apply-next-steps";
---

<Layout title={`${module.title} | CSPB Info Session`} active={module.id}>
  <article class="stack-lg">
    <header class="hero-panel">
      <div class="hero-inner">
        <div>
          <p class="kicker">Module</p>
          <h1 class="heading-xl mt-4">{module.title}</h1>
          <p class="lede mt-4">{module.question}</p>
          <div class="hero-actions">
            {module.primaryCta?.urlKey && <CTAButton href={module.primaryCta.urlKey} label={module.primaryCta.label} variant="gold" />}
            {module.primaryCta?.url && <CTAButton href={module.primaryCta.url} label={module.primaryCta.label} variant="gold" />}
            <CTAButton href="/dashboard/" label="Back to dashboard" variant="secondary" />
          </div>
        </div>

        {module.image ? (
          <div class="overflow-hidden rounded-[1.5rem] border border-white/10 bg-black/20 p-2 shadow-xl">
            <img
              src={moduleImageSrc}
              alt={`${module.title} module illustration`}
              class="block h-full min-h-56 w-full rounded-[1.1rem] object-cover"
              loading="eager"
            />
          </div>
        ) : (
          <VideoPlaceholder title={`${module.title} video`} duration={isCurriculum ? "4–5 minutes" : isAdmissions ? "3–4 minutes" : "2–4 minutes"} compact={true} />
        )}
      </div>
    </header>

    <section class="auto-grid-tight">
      <article class="card card-pad">
        <p class="kicker">Question</p>
        <h2 class="heading-md mt-2">What this answers</h2>
        <p class="mt-3 text-sm leading-6 text-neutral-600">{module.question}</p>
      </article>

      <article class="card card-pad">
        <p class="kicker">Overview</p>
        <h2 class="heading-md mt-2">What you’ll learn</h2>
        <p class="mt-3 text-sm leading-6 text-neutral-600">{module.summary}</p>
      </article>

      <article class="card card-pad">
        <p class="kicker">Next step</p>
        <h2 class="heading-md mt-2">Continue from here</h2>
        <p class="mt-3 text-sm leading-6 text-neutral-600">
          Use this module to continue through the self-guided session, visit the related official page, or contact the CSPB team with questions.
        </p>
        <div class="mt-5">
          {module.primaryCta?.urlKey && <CTAButton href={module.primaryCta.urlKey} label={module.primaryCta.label} variant="dark" />}
          {module.primaryCta?.url && <CTAButton href={module.primaryCta.url} label={module.primaryCta.label} variant="dark" />}
        </div>
      </article>
    </section>

    {isOverview && <ProgramOverviewContent />}

    {isApply && <ApplyNextStepsContent />}

    {isCareer && (
      <section class="stack">
        <div>
          <p class="kicker">Career outcomes</p>
          <h2 class="heading-lg mt-2">Outcome areas</h2>
        </div>
        <div class="auto-grid">
          {outcomes.panels.map((panel) => <OutcomePanel panel={panel} />)}
        </div>
      </section>
    )}

    {isCurriculum && (
      <section class="stack">
        <div>
          <p class="kicker">Curriculum overview</p>
          <h2 class="heading-lg mt-2">Courses and pacing</h2>
        </div>
        <CourseTable title="Required courses" courses={courses.required} />
        <CourseTable title="Elective courses" courses={courses.electives} note="Elective availability may vary by term. Confirm details on the official curriculum page." />
        <SamplePacing />
      </section>
    )}

    {isAdmissions && (
      <section class="stack">
        <div>
          <p class="kicker">Admissions overview</p>
          <h2 class="heading-lg mt-2">{admissions.headline}</h2>
        </div>
        <AdmissionsChecklist admissions={admissions} />
      </section>
    )}

    {!isOverview && !isApply && !isCareer && !isCurriculum && !isAdmissions && (
      <section class="card card-pad">
        <p class="kicker">About this module</p>
        <h2 class="heading-lg mt-2">A quick orientation</h2>
        <p class="lede mt-3">
          This module gives a focused overview of one part of the CSPB program. Use the dashboard to continue through the rest of the self-guided information session.
        </p>
      </section>
    )}

    {relatedFaqs.length > 0 && (
      <section class="stack">
        <h2 class="heading-lg">Related questions</h2>
        <FAQAccordion faqs={relatedFaqs} />
      </section>
    )}

    <GlobalCTA />
  </article>
</Layout>
