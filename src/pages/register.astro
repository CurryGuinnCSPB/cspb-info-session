---
import Layout from "../components/Layout.astro";
import CTAButton from "../components/CTAButton.astro";
const base = import.meta.env.BASE_URL || "/";
---

<Layout title="Mock Qualtrics Intake" showSidebar={false}>
  <section class="mx-auto max-w-4xl rounded-[2rem] bg-neutral-950 p-1 shadow-xl">
    <div class="rounded-[1.85rem] bg-white p-8 lg:p-10">
      <p class="text-sm font-black uppercase tracking-[0.2em] text-[#8b6f24]">Mock Qualtrics step</p>
      <h1 class="mt-3 text-5xl font-black tracking-tight text-neutral-950">Tell us a little about yourself</h1>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-neutral-700">
        In production, this step will link to or embed a CU Boulder Qualtrics form. For the mockup, no information is collected.
      </p>

      <div class="mt-8 grid gap-4 rounded-[1.5rem] bg-neutral-50 p-6 ring-1 ring-neutral-200">
        <div>
          <label class="text-sm font-black text-neutral-800">Name</label>
          <div class="mt-2 rounded-xl border border-neutral-200 bg-white px-4 py-3 text-neutral-400">Qualtrics field placeholder</div>
        </div>
        <div>
          <label class="text-sm font-black text-neutral-800">Email</label>
          <div class="mt-2 rounded-xl border border-neutral-200 bg-white px-4 py-3 text-neutral-400">Qualtrics field placeholder</div>
        </div>
        <div>
          <label class="text-sm font-black text-neutral-800">Topics of interest</label>
          <div class="mt-2 rounded-xl border border-neutral-200 bg-white px-4 py-3 text-neutral-400">Admissions, curriculum, tuition, career outcomes...</div>
        </div>
      </div>

      <div class="mt-8 flex flex-wrap gap-3">
        <button id="complete-registration" class="focus-ring inline-flex rounded-full bg-neutral-950 px-5 py-3 text-sm font-black text-white shadow-lg hover:bg-neutral-800">
          Simulate form completion
        </button>
        <CTAButton href="/" label="Return to landing page" variant="secondary" />
      </div>
    </div>
  </section>

  <script is:inline define:vars={{ base }}>
    const button = document.getElementById("complete-registration");
    button?.addEventListener("click", () => {
      localStorage.setItem("cspb_info_session_registered", "true");
      localStorage.setItem("cspb_info_session_registered_at", new Date().toISOString());
      window.location.href = `${base.replace(/\/$/, "")}/dashboard/`;
    });
  </script>
</Layout>
