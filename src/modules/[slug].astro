---
import Layout from "../../components/Layout.astro";
import VideoPlaceholder from "../../components/VideoPlaceholder.astro";
import GlobalCTA from "../../components/GlobalCTA.astro";
import CourseTable from "../../components/CourseTable.astro";
import FAQAccordion from "../../components/FAQAccordion.astro";
import CTAButton from "../../components/CTAButton.astro";
import OutcomePanel from "../../components/OutcomePanel.astro";
import AdmissionsChecklist from "../../components/AdmissionsChecklist.astro";
import SamplePacing from "../../components/SamplePacing.astro";
import ReviewNote from "../../components/ReviewNote.astro";

import modules from "../../data/modules.json";
import courses from "../../data/courses.json";
import faqs from "../../data/faqs.json";
import outcomes from "../../data/outcomes.json";
import admissions from "../../data/admissions.json";

export function getStaticPaths() {
  return modules
    .filter((module) => module.id !== "start-here")
    .map((module) => ({
      params: { slug: module.slug },
      props: { module }
    }));
}

const { module } = Astro.props;
const relatedFaqs = faqs.filter((faq) => faq.relatedModules?.includes(module.id));
const isCareer = module.id === "career-outcomes";
const isCurriculum = module.id === "curriculum";
const isAdmissions = module.id === "admissions-requirements";
---

<Layout title={`${module.title} | CSPB Info Session`} active={module.id}>
  <article class="space-y-8">
    <header class="relative overflow-hidden rounded-[2rem] bg-neutral-950 p-8 text-white shadow-xl lg:p-10">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_15%_25%,rgba(207,184,124,0.24),transparent_24rem),radial-gradient(circle_at_90%_20%,rgba(52,85,111,0.34),transparent_26rem)]"></div>
      <div class="relative">
        <p class="text-sm font-black uppercase tracking-[0.2em] text-[#cfb87c]">Module</p>
        <h1 class="mt-3 max-w-4xl text-5xl font-black tracking-tight">{module.title}</h1>
        <p class="mt-5 max-w-3xl text-xl font-bold leading-8 text-neutral-200">{module.question}</p>
        <p class="mt-4 max-w-3xl text-lg leading-8 text-neutral-300">{module.summary}</p>
        <p class="mt-5 inline-flex rounded-full border border-white/10 bg-white/10 px-4 py-2 text-sm text-neutral-300">
          Source slide reference for internal review: {module.sourceSlides?.join(", ")}
        </p>

        <div class="mt-7 flex flex-wrap gap-3">
          {module.primaryCta?.urlKey && <CTAButton href={module.primaryCta.urlKey} label={module.primaryCta.label} variant="gold" />}
          {module.primaryCta?.url && <CTAButton href={module.primaryCta.url} label={module.primaryCta.label} variant="gold" />}
          <CTAButton href="/dashboard/" label="Back to dashboard" variant="secondary" />
        </div>
      </div>
    </header>

    <VideoPlaceholder title={`${module.title} video`} duration={isCurriculum ? "4–5 minutes" : isAdmissions ? "3–4 minutes" : "2–4 minutes"} />

    {isCareer && (
      <section class="space-y-6">
        <div class="rounded-[1.75rem] border border-neutral-200 bg-white p-6 shadow-sm">
          <p class="text-xs font-black uppercase tracking-[0.18em] text-[#8b6f24]">Career outcomes</p>
          <h2 class="mt-2 text-3xl font-black text-neutral-950">What this module should show</h2>
          <p class="mt-3 max-w-4xl text-base leading-7 text-neutral-600">{outcomes.summary}</p>
        </div>

        <div class="grid gap-5 xl:grid-cols-3">
          {outcomes.panels.map((panel) => <OutcomePanel panel={panel} />)}
        </div>

        <ReviewNote title="Outcomes review required" risk="high">
          <p>{outcomes.methodologyNote}</p>
          <ul class="mt-3 list-disc pl-5">
            {outcomes.caveats.map((caveat) => <li>{caveat}</li>)}
          </ul>
        </ReviewNote>
      </section>
    )}

    {isCurriculum && (
      <section class="space-y-6">
        <div class="rounded-[1.75rem] border border-neutral-200 bg-white p-6 shadow-sm">
          <p class="text-xs font-black uppercase tracking-[0.18em] text-[#8b6f24]">Curriculum overview</p>
          <h2 class="mt-2 text-3xl font-black text-neutral-950">Required courses, electives, and possible pacing</h2>
          <p class="mt-3 max-w-4xl text-base leading-7 text-neutral-600">
            This module turns the course-list slide into a navigable curriculum page. The production version should verify course titles, credit hours, availability, elective rotation, and pathway language against official sources.
          </p>
        </div>

        <CourseTable title="Required courses" courses={courses.required} note="Required course data is from the current information-session deck and should be verified against the official catalog." />
        <CourseTable title="Elective courses" courses={courses.electives} note={courses.electiveAvailabilityNote} />
        <SamplePacing />

        <ReviewNote title="Curriculum review required" risk="high">
          Course lists, credit hours, course availability, and pathway labels should be verified before production. This page should not become the official catalog.
        </ReviewNote>
      </section>
    )}

    {isAdmissions && (
      <section class="space-y-6">
        <div class="rounded-[1.75rem] border border-neutral-200 bg-white p-6 shadow-sm">
          <p class="text-xs font-black uppercase tracking-[0.18em] text-[#8b6f24]">Admissions overview</p>
          <h2 class="mt-2 text-3xl font-black text-neutral-950">{admissions.headline}</h2>
          <p class="mt-3 max-w-4xl text-base leading-7 text-neutral-600">{admissions.summary}</p>
        </div>

        <AdmissionsChecklist admissions={admissions} />

        <div class="grid gap-5 lg:grid-cols-2">
          <ReviewNote title="Deadline language" risk="high">
            {admissions.deadlineNote}
          </ReviewNote>
          <ReviewNote title="Application fee language" risk="high">
            {admissions.feeNote}
          </ReviewNote>
        </div>
      </section>
    )}

    {!isCareer && !isCurriculum && !isAdmissions && (
      <section class="rounded-[1.75rem] border border-neutral-200 bg-white p-6 shadow-sm">
        <p class="text-xs font-black uppercase tracking-[0.18em] text-[#8b6f24]">Generated page</p>
        <h2 class="mt-2 text-3xl font-black text-neutral-950">Module content placeholder</h2>
        <p class="mt-3 max-w-3xl leading-7 text-neutral-600">
          This module page is generated from <code>modules.json</code>. Future versions can add custom content, charts, tables, FAQs, or embedded videos for this topic.
        </p>
      </section>
    )}

    {relatedFaqs.length > 0 && (
      <section>
        <h2 class="mb-4 text-3xl font-black text-neutral-950">Related questions</h2>
        <FAQAccordion faqs={relatedFaqs} />
      </section>
    )}

    <GlobalCTA />
  </article>
</Layout>
