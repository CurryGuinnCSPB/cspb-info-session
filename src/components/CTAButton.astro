---
import { resolveLink } from "../utils/resolveLink.js";

const {
  href = "#",
  label = "Learn more",
  variant = "primary",
  class: className = "",
  dataEvent = "cta_click",
  dataCta = label
} = Astro.props;

const styles = {
  primary: "bg-neutral-950 text-white hover:bg-neutral-800",
  secondary: "bg-white text-neutral-950 ring-1 ring-neutral-300 hover:bg-neutral-100",
  gold: "bg-yellow-500 text-neutral-950 hover:bg-yellow-400",
  ghost: "bg-transparent text-neutral-950 hover:bg-neutral-100"
};

const buttonClass = `${styles[variant] || styles.primary} inline-flex items-center justify-center rounded-full px-5 py-3 text-sm font-semibold shadow-sm transition focus-ring ${className}`;
---

<a class={buttonClass} href={resolveLink(href)} data-event={dataEvent} data-cta={dataCta}>
  {label}
</a>
