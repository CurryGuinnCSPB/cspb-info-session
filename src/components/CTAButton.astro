---
import { resolveLink } from "../utils/resolveLink.js";

const {
  href = "#",
  label = "Learn more",
  variant = "primary",
  class: className = "",
  dataEvent = "cta_click",
  dataCta = label
} = Astro.props;

const styles = {
  primary: "bg-neutral-950 text-white hover:bg-neutral-800 shadow-neutral-950/15",
  secondary: "bg-white text-neutral-950 ring-1 ring-neutral-300 hover:bg-neutral-100 shadow-neutral-950/5",
  gold: "bg-[#cfb87c] text-neutral-950 hover:bg-[#d8c58d] shadow-[#cfb87c]/25",
  ghost: "bg-transparent text-neutral-950 hover:bg-neutral-100 shadow-none"
};

const buttonClass = `${styles[variant] || styles.primary} inline-flex items-center justify-center rounded-full px-5 py-3 text-sm font-black shadow-lg transition duration-200 hover:-translate-y-0.5 focus-ring ${className}`;
---

<a class={buttonClass} href={resolveLink(href)} data-event={dataEvent} data-cta={dataCta}>
  {label}
</a>
