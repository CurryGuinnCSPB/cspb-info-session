---
import CTAButton from "./CTAButton.astro";

const admissionsUrl = "https://online.colorado.edu/applied-computer-science-bs/admissions";
const deadlinesUrl = "https://online.colorado.edu/applied-computer-science-bs-post-baccalaureate/dates-and-deadlines";
const aleksUrl = "https://online.colorado.edu/applied-computer-science-bs/admissions#ucb-accordion-id--4-content2";

const requirements = [
  {
    title: "Bachelor’s degree",
    body: "You must already have a bachelor’s degree before entering the degree program."
  },
  {
    title: "Minimum GPA",
    body: "The standard minimum GPA requirement is 2.75. If your GPA is below the requirement, the optional personal essay may help you explain your academic record, preparation, and readiness for the program."
  },
  {
    title: "Math prerequisite",
    body: "You must satisfy the math prerequisite. Current options include CU ALEKS College Algebra or qualifying calculus / AP Calculus coursework with the required grade.",
    link: aleksUrl,
    linkLabel: "Review the math prerequisite and CU ALEKS information"
  },
  {
    title: "Transcripts",
    body: "You will need to submit transcripts from all higher-education institutions you have attended."
  }
];

const applicationMaterials = [
  "All higher-education transcripts",
  "Program questionnaire",
  "Optional personal essay",
  "Math prerequisite documentation when needed"
];

const steps = [
  {
    title: "1. Confirm the degree requirement",
    body: "Make sure you have already completed a bachelor’s degree or will have completed one before beginning the program."
  },
  {
    title: "2. Check the GPA and math requirements",
    body: "Review the GPA requirement and make sure you understand how you will satisfy the math prerequisite.",
    link: admissionsUrl,
    linkLabel: "Review admissions requirements"
  },
  {
    title: "3. Review the official deadline page",
    body: "Application deadlines vary by term. Use the official dates and deadlines page to confirm the deadline for the term you want to enter.",
    link: deadlinesUrl,
    linkLabel: "View dates and deadlines"
  },
  {
    title: "4. Gather your materials",
    body: "Prepare transcripts, complete the program questionnaire, and decide whether the optional personal essay would strengthen your application."
  },
  {
    title: "5. Submit the application",
    body: "Applications are currently free. Submit all required materials by the posted deadline.",
    link: admissionsUrl,
    linkLabel: "Go to the official admissions page"
  }
];

const essayUses = [
  "Your GPA is below the standard requirement.",
  "Your academic record needs context.",
  "You had extenuating circumstances that affected your grades.",
  "You want to explain preparation, motivation, and readiness for the program."
];
---

<section class="stack">
  <div>
    <p class="kicker">Admissions requirements</p>
    <h2 class="heading-lg mt-2">Confirm eligibility, gather materials, and apply by the deadline</h2>
    <p class="lede mt-4">
      The Computer Science Post-Baccalaureate Program (CSPB) is for students who already have a bachelor’s degree and want to earn the BS in Applied Computer Science from CU Boulder. The application process focuses on a few core items: degree status, GPA, math preparation, transcripts, and the program questionnaire.
    </p>
  </div>

  <div class="auto-grid">
    {requirements.map((item) => (
      <article class="card card-pad">
        <h3 class="heading-md">{item.title}</h3>
        <p class="mt-3 text-sm leading-6 text-neutral-600">{item.body}</p>
        {item.link && (
          <p class="mt-4">
            <a class="text-sm font-black text-neutral-950 underline decoration-[#cfb87c] decoration-2 underline-offset-4" href={item.link}>
              {item.linkLabel}
            </a>
          </p>
        )}
      </article>
    ))}
  </div>
</section>

<section class="card card-pad">
  <div class="grid gap-6 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
    <div>
      <p class="kicker">Dates and deadlines</p>
      <h2 class="heading-lg mt-2">Check the official deadline for your entry term</h2>
      <p class="mt-4 text-sm leading-6 text-neutral-600">
        Application deadlines vary by term. Use the <a class="font-black text-neutral-950 underline decoration-[#cfb87c] decoration-2 underline-offset-4" href={deadlinesUrl}>official CU Boulder dates and deadlines page</a> to confirm the current deadline for the term you want to enter.
      </p>
      <p class="mt-4 text-sm leading-6 text-neutral-600">
        All application materials must be submitted by the posted deadline. That includes transcripts, the program questionnaire, and any optional materials you choose to submit.
      </p>
      <div class="mt-5">
        <a class="btn btn-dark" href={deadlinesUrl}>
          View dates and deadlines
        </a>
      </div>
    </div>

    <div class="rounded-[1.25rem] bg-neutral-950 p-5 text-white">
      <p class="text-4xl font-black text-[#cfb87c]">Free</p>
      <p class="mt-3 text-sm font-bold leading-6 text-white/80">
        Applications are currently free.
      </p>
      <p class="mt-3 text-xs leading-5 text-white/60">
        Students should still submit all required materials by the posted deadline.
      </p>
    </div>
  </div>
</section>

<section class="card card-pad">
  <div class="grid gap-6 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
    <div>
      <p class="kicker">Math prerequisite</p>
      <h2 class="heading-lg mt-2">CU ALEKS is one way to satisfy the math requirement</h2>
      <p class="mt-4 text-sm leading-6 text-neutral-600">
        Students must satisfy the math prerequisite before entering the degree program. One current option is CU ALEKS College Algebra. Students may also be able to use qualifying calculus or AP Calculus coursework with the required grade.
      </p>
      <p class="mt-4 text-sm leading-6 text-neutral-600">
        The official admissions page includes the current math-prerequisite details. Review the <a class="font-black text-neutral-950 underline decoration-[#cfb87c] decoration-2 underline-offset-4" href={aleksUrl}>CU ALEKS and math prerequisite section</a> before making a plan.
      </p>
      <div class="mt-5">
        <a class="btn btn-dark" href={aleksUrl}>
          Review CU ALEKS information
        </a>
      </div>
    </div>

    <div class="rounded-[1.25rem] border border-neutral-200 bg-neutral-50 p-5">
      <p class="kicker">Plan ahead</p>
      <p class="mt-2 text-sm font-bold leading-6 text-neutral-700">
        Students who need CU ALEKS should leave enough time to complete the math requirement before the admissions deadline for their entry term.
      </p>
    </div>
  </div>
</section>

<section class="stack">
  <div>
    <p class="kicker">Application materials</p>
    <h2 class="heading-lg mt-2">What you submit</h2>
  </div>

  <div class="grid gap-4 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
    <div class="card card-pad">
      <ul class="space-y-3 text-sm leading-6 text-neutral-700">
        {applicationMaterials.map((item) => <li>• {item}</li>)}
      </ul>
      <p class="mt-5 text-sm leading-6 text-neutral-600">
        Review the <a class="font-black text-neutral-950 underline decoration-[#cfb87c] decoration-2 underline-offset-4" href={admissionsUrl}>official admissions page</a> for current application requirements.
      </p>
    </div>

    <div class="card card-pad">
      <h3 class="heading-md">Personal essay</h3>
      <p class="mt-3 text-sm leading-6 text-neutral-600">
        The personal essay is optional. It may be beneficial if your GPA is below the required threshold or if your academic record would benefit from additional explanation.
      </p>
      <div class="mt-4 grid gap-2">
        {essayUses.map((item) => (
          <div class="rounded-[1rem] border border-neutral-200 bg-neutral-50 p-3 text-sm font-bold leading-6 text-neutral-700">
            {item}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<section class="stack">
  <div>
    <p class="kicker">Application path</p>
    <h2 class="heading-lg mt-2">A simple application sequence</h2>
  </div>

  <div class="grid gap-4">
    {steps.map((step) => (
      <article class="card card-pad">
        <h3 class="heading-md">{step.title}</h3>
        <p class="mt-3 text-sm leading-6 text-neutral-600">{step.body}</p>
        {step.link && (
          <p class="mt-4">
            <a class="text-sm font-black text-neutral-950 underline decoration-[#cfb87c] decoration-2 underline-offset-4" href={step.link}>
              {step.linkLabel}
            </a>
          </p>
        )}
      </article>
    ))}
  </div>
</section>

<section class="card card-pad">
  <div class="grid gap-6 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
    <div>
      <p class="kicker">Non-degree option</p>
      <h2 class="heading-lg mt-2">Only want to take a few courses?</h2>
      <p class="mt-4 text-sm leading-6 text-neutral-600">
        If you are not intending to earn the degree and only want to take a few courses, investigate the non-degree option. This can be useful for students seeking graduate-school prerequisites, professional development, or a way to try CSPB courses before applying to the degree program.
      </p>
      <div class="mt-5">
        <CTAButton href="/modules/non-degree-option/" label="Review non-degree option" variant="dark" />
      </div>
    </div>

    <div class="rounded-[1.25rem] border border-neutral-200 bg-neutral-50 p-5">
      <p class="kicker">Different goal</p>
      <p class="mt-2 text-sm font-bold leading-6 text-neutral-700">
        Degree-seeking admission is for students pursuing the BS in Applied Computer Science. Non-degree enrollment is for students who want selected courses.
      </p>
    </div>
  </div>
</section>

<section class="card card-pad border-l-4 border-l-[#cfb87c]">
  <p class="kicker">Questions</p>
  <h2 class="heading-md mt-2">Talk with the CSPB team</h2>
  <p class="mt-3 text-sm leading-6 text-neutral-600">
    If you have questions about admission, eligibility, application timing, or the right next step, contact the CSPB team or schedule an appointment.
  </p>
  <div class="mt-5 flex flex-wrap gap-3">
    <a class="btn btn-dark" href={admissionsUrl}>Official admissions page</a>
    <a class="btn btn-secondary" href="mailto:cspbonline@colorado.edu">Email cspbonline@colorado.edu</a>
    <CTAButton href="scheduleAppointment" label="Schedule an appointment" variant="secondary" />
  </div>
</section>
