---
import modules from "../data/modules.json";
import links from "../data/links.json";
import { resolveLink } from "../utils/resolveLink.js";

const { active = "" } = Astro.props;
const navModules = modules.filter((m) => m.id !== "start-here");
---

<aside class="sidebar-shell bg-neutral-950 p-4 text-white">
  <div class="rounded-3xl border border-white/10 bg-white/5 p-4">
    <a href={resolveLink("/dashboard/")} class="focus-ring block rounded-xl">
      <p class="text-xs font-black uppercase tracking-[0.22em] text-[#cfb87c]">CU Boulder</p>
      <h1 class="mt-2 text-xl font-black leading-tight">CSPB Info Session</h1>
      <p class="mt-2 text-xs leading-5 text-neutral-400">Self-guided admissions overview</p>
    </a>
  </div>

  <nav class="mt-4 space-y-1" aria-label="Primary navigation">
    <a class={`block rounded-2xl px-3 py-2.5 text-sm font-black transition ${active === "dashboard" ? "bg-[#cfb87c] text-neutral-950" : "text-neutral-300 hover:bg-white/10 hover:text-white"}`} href={resolveLink("/dashboard/")}>Start Here</a>
    {navModules.map((module) => (
      <a
        class={`block rounded-2xl px-3 py-2.5 text-sm font-bold transition ${active === module.id ? "bg-[#cfb87c] text-neutral-950" : "text-neutral-300 hover:bg-white/10 hover:text-white"}`}
        href={resolveLink(`/modules/${module.slug}/`)}
      >
        {module.navLabel}
      </a>
    ))}
    <a class={`block rounded-2xl px-3 py-2.5 text-sm font-bold transition ${active === "faq" ? "bg-[#cfb87c] text-neutral-950" : "text-neutral-300 hover:bg-white/10 hover:text-white"}`} href={resolveLink("/faq/")}>FAQ</a>
  </nav>

  <div class="mt-5 rounded-3xl border border-white/10 bg-white/5 p-4">
    <p class="text-sm font-black text-white">Questions?</p>
    <p class="mt-2 text-xs leading-5 text-neutral-400">Contact the CSPB team or schedule an appointment.</p>
    <div class="mt-4 grid gap-2">
      <a class="focus-ring rounded-full bg-[#cfb87c] px-4 py-2 text-center text-sm font-black text-neutral-950 hover:bg-[#d8c58d]" href={links.apply}>Apply</a>
      <a class="focus-ring rounded-full bg-white px-4 py-2 text-center text-sm font-black text-neutral-950 hover:bg-neutral-100" href={links.contactEmail}>Email</a>
    </div>
  </div>
</aside>
