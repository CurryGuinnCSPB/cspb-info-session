---
import CTAButton from "./CTAButton.astro";
import VideoPlaceholder from "./VideoPlaceholder.astro";
---

<section class="hero-panel">
  <div class="hero-inner">
    <div>
      <div class="inline-flex rounded-full border border-white/15 bg-white/10 px-3.5 py-1.5 text-xs font-black uppercase tracking-[0.2em] text-[#cfb87c]">
        Self-guided info session
      </div>
      <h1 class="heading-xl mt-4">Build computer science on top of the degree you already have.</h1>
      <p class="lede mt-4 max-w-3xl">
        Explore CU Boulder’s online Computer Science Post-Baccalaureate Program through short modules organized around prospective student questions.
      </p>
      <div class="hero-actions">
        <CTAButton href="/modules/program-overview/" label="Watch overview" variant="gold" />
        <CTAButton href="/modules/curriculum/" label="Explore curriculum" variant="secondary" />
        <CTAButton href="scheduleAppointment" label="Talk to an advisor" variant="secondary" />
      </div>
    </div>
    <VideoPlaceholder title="CSPB overview video" duration="2–3 minutes" compact={true} />
  </div>
</section>
