---
import programFacts from "../data/programFacts.json";
---

<section class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
  {programFacts.map((fact) => (
    <article class="card card-pad">
      <p class="text-3xl font-black tracking-tight text-neutral-950">{fact.value}</p>
      <p class="mt-2 text-sm font-bold leading-6 text-neutral-600">{fact.label}</p>
    </article>
  ))}
</section>
