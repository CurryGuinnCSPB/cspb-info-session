---
const { facts = [] } = Astro.props;
---

<section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4" aria-label="Program highlights">
  {facts.map((fact) => (
    <article class="rounded-3xl border border-neutral-200 bg-white p-5 shadow-sm">
      <p class="text-4xl font-black tracking-tight text-neutral-950">{fact.value}</p>
      <p class="mt-2 text-sm font-medium text-neutral-700">{fact.label}</p>
      <p class="mt-3 text-xs text-neutral-500">Mockup data · {fact.reviewStatus}</p>
    </article>
  ))}
</section>
