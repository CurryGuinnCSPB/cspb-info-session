---
const { facts = [] } = Astro.props;
---

<section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4" aria-label="Program highlights">
  {facts.map((fact, index) => (
    <article class="group relative overflow-hidden rounded-[1.75rem] border border-neutral-200 bg-white p-6 shadow-sm transition duration-200 hover:-translate-y-0.5 hover:shadow-lg">
      <div class="absolute -right-8 -top-8 h-24 w-24 rounded-full bg-[#cfb87c]/20 transition group-hover:scale-125"></div>
      <div class="relative">
        <p class="text-xs font-black uppercase tracking-[0.18em] text-neutral-500">Highlight {index + 1}</p>
        <p class="mt-3 text-5xl font-black tracking-tight text-neutral-950">{fact.value}</p>
        <p class="mt-3 min-h-12 text-sm font-bold leading-6 text-neutral-700">{fact.label}</p>
        <p class="mt-4 inline-flex rounded-full bg-neutral-100 px-3 py-1 text-xs font-semibold text-neutral-500">
          Verify before launch
        </p>
      </div>
    </article>
  ))}
</section>
