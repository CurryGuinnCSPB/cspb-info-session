---
const { facts = [] } = Astro.props;
---

<section class="auto-grid-tight" aria-label="Program highlights">
  {facts.map((fact) => (
    <article class="card card-pad min-w-0">
      <p class="text-5xl font-black tracking-tight text-neutral-950">{fact.value}</p>
      <p class="mt-3 text-sm font-bold leading-6 text-neutral-700">{fact.label}</p>
      <p class="mt-4 text-xs font-semibold text-neutral-500">Verify before launch</p>
    </article>
  ))}
</section>
