---
import modules from "../data/modules.json";
import { resolveLink } from "../utils/resolveLink.js";
---

<header class="sticky top-0 z-40 border-b border-neutral-200 bg-white/95 px-4 py-3 backdrop-blur lg:hidden">
  <details>
    <summary class="focus-ring flex cursor-pointer list-none items-center justify-between rounded-xl px-2 py-2 font-black text-neutral-950">
      <span>
        <span class="block text-xs uppercase tracking-[0.18em] text-[#8b6f24]">CU Boulder</span>
        CSPB Info Session
      </span>
      <span class="rounded-full bg-neutral-950 px-3 py-1 text-sm text-white">Menu</span>
    </summary>
    <nav class="mt-3 grid gap-1 pb-2" aria-label="Mobile navigation">
      <a class="rounded-xl px-3 py-2 font-bold text-neutral-800 hover:bg-neutral-100" href={resolveLink("/dashboard/")}>Start Here</a>
      {modules.filter((m) => m.id !== "start-here").map((module) => (
        <a class="rounded-xl px-3 py-2 font-bold text-neutral-800 hover:bg-neutral-100" href={resolveLink(`/modules/${module.slug}/`)}>
          {module.navLabel}
        </a>
      ))}
      <a class="rounded-xl px-3 py-2 font-bold text-neutral-800 hover:bg-neutral-100" href={resolveLink("/faq/")}>FAQ</a>
    </nav>
  </details>
</header>
