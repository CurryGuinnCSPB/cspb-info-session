---
import modules from "../data/modules.json";
import { resolveLink } from "../utils/resolveLink.js";
---

<header class="border-b border-neutral-200 bg-white px-4 py-3 lg:hidden">
  <details>
    <summary class="focus-ring flex cursor-pointer list-none items-center justify-between rounded-xl px-2 py-2 font-bold text-neutral-950">
      CSPB Info Session
      <span>Menu</span>
    </summary>
    <nav class="mt-3 grid gap-1 pb-2" aria-label="Mobile navigation">
      <a class="rounded-xl px-3 py-2 font-semibold text-neutral-800 hover:bg-neutral-100" href={resolveLink("/dashboard/")}>Start Here</a>
      {modules.filter((m) => m.id !== "start-here").map((module) => (
        <a class="rounded-xl px-3 py-2 font-semibold text-neutral-800 hover:bg-neutral-100" href={resolveLink(`/modules/${module.slug}/`)}>
          {module.navLabel}
        </a>
      ))}
      <a class="rounded-xl px-3 py-2 font-semibold text-neutral-800 hover:bg-neutral-100" href={resolveLink("/faq/")}>FAQ</a>
    </nav>
  </details>
</header>
