---
const {
  title = "Internal review note",
  risk = "medium",
  children
} = Astro.props;
---

<aside class="rounded-[1.5rem] border border-amber-200 bg-amber-50 p-5 text-sm text-amber-950">
  <p class="font-black">{title}</p>
  <div class="mt-2 leading-6">
    <slot />
  </div>
  <p class="mt-3 inline-flex rounded-full bg-white px-3 py-1 text-xs font-black text-amber-900">
    Risk level: {risk}
  </p>
</aside>
