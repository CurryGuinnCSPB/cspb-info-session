---
const plans = [
  {
    title: "Part-time exploratory pace",
    description: "One course in a term can help students test workload, refresh preparation, or begin through the non-degree option.",
    courses: "1 course / term"
  },
  {
    title: "Common part-time pace",
    description: "Many students take one or two classes per semester while balancing work, family, and other responsibilities.",
    courses: "1–2 courses / term"
  },
  {
    title: "Advisor-planned pace",
    description: "Students with transfer credit, prerequisite questions, or graduate-school goals should discuss sequencing with advising.",
    courses: "Plan with advisor"
  }
];
---

<section class="rounded-[1.75rem] border border-neutral-200 bg-white p-6 shadow-sm">
  <p class="text-xs font-black uppercase tracking-[0.18em] text-[#8b6f24]">Sample pacing</p>
  <h2 class="mt-2 text-3xl font-black text-neutral-950">How students might move through the program</h2>
  <p class="mt-3 max-w-3xl text-sm leading-6 text-neutral-600">
    These are mockup planning cards, not official advising plans. Production versions should be reviewed by advising and curriculum leadership.
  </p>

  <div class="mt-6 grid gap-5 lg:grid-cols-3">
    {plans.map((plan) => (
      <article class="rounded-[1.5rem] bg-neutral-50 p-5">
        <p class="text-3xl font-black text-neutral-950">{plan.courses}</p>
        <h3 class="mt-3 text-lg font-black text-neutral-950">{plan.title}</h3>
        <p class="mt-2 text-sm leading-6 text-neutral-600">{plan.description}</p>
      </article>
    ))}
  </div>
</section>
