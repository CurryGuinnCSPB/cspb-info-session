---
const { title = "Courses", courses = [], note = "" } = Astro.props;
const totalCredits = courses.reduce((sum, course) => sum + Number(course.credits || 0), 0);
---

<section class="card card-pad">
  <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
    <div>
      <p class="kicker">Course list</p>
      <h2 class="heading-md mt-2">{title}</h2>
      {note && <p class="mt-2 max-w-3xl text-sm leading-6 text-neutral-600">{note}</p>}
    </div>
    <div class="w-fit rounded-2xl bg-neutral-950 px-5 py-3 text-white">
      <p class="text-xs font-bold uppercase tracking-wide text-[#cfb87c]">Listed credits</p>
      <p class="text-2xl font-black">{totalCredits}</p>
    </div>
  </div>

  <div class="table-scroll mt-6">
    <table class="w-full border-collapse text-left text-sm">
      <thead>
        <tr class="bg-neutral-950 text-white">
          <th class="py-4 pl-5 pr-4 font-black">Course</th>
          <th class="py-4 pr-4 font-black">Title</th>
          <th class="py-4 pr-4 font-black">Credits</th>
          <th class="py-4 pr-5 font-black">Availability</th>
        </tr>
      </thead>
      <tbody class="bg-white">
        {courses.map((course) => (
          <tr class="border-b border-neutral-100 last:border-0">
            <td class="py-4 pl-5 pr-4 font-black text-neutral-950">{course.courseNumber}</td>
            <td class="py-4 pr-4 text-neutral-700">{course.title}</td>
            <td class="py-4 pr-4 font-bold text-neutral-700">{course.credits}</td>
            <td class="py-4 pr-5 text-neutral-600">{course.availability || "See current schedule"}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>
