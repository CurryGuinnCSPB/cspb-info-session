---
import { resolveLink } from "../utils/resolveLink.js";

const { module } = Astro.props;
const cta = module.primaryCta || {};
const href = cta.urlKey ? cta.urlKey : (cta.url || `/modules/${module.slug}/`);
const label = cta.label || "View module";
---

<article class="group flex h-full flex-col rounded-3xl border border-neutral-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
  <div class="mb-4 flex items-start justify-between gap-4">
    <div class="flex h-11 w-11 items-center justify-center rounded-2xl bg-neutral-100 text-lg font-black text-neutral-900">
      {module.icon?.slice(0, 1).toUpperCase() || "•"}
    </div>
    {module.statusTag && (
      <span class="rounded-full bg-yellow-100 px-3 py-1 text-xs font-bold text-neutral-900">
        {module.statusTag}
      </span>
    )}
  </div>

  <h2 class="text-xl font-bold text-neutral-950">{module.title}</h2>
  <p class="mt-2 text-sm font-semibold text-neutral-600">{module.question}</p>
  <p class="mt-3 flex-1 text-sm leading-6 text-neutral-600">{module.summary}</p>

  <a
    class="focus-ring mt-6 inline-flex font-semibold text-neutral-950 group-hover:underline"
    href={resolveLink(href)}
    data-event="module_card_click"
    data-module={module.id}
  >
    {label} →
  </a>
</article>
