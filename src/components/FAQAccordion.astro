---
const { faqs = [] } = Astro.props;
const categories = [...new Set(faqs.map((faq) => faq.category))];
---

<section class="auto-grid-wide">
  {categories.map((category) => (
    <div class="card card-pad">
      <h2 class="text-xl font-black text-neutral-950">{category}</h2>
      <div class="mt-3 divide-y divide-neutral-100">
        {faqs.filter((faq) => faq.category === category).map((faq) => (
          <details class="group py-3">
            <summary class="focus-ring cursor-pointer list-none rounded-xl font-bold text-neutral-950">
              <span class="inline-flex w-full items-center justify-between gap-4">
                <span class="text-sm leading-6">{faq.question}</span>
                <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-neutral-100 text-neutral-600 transition group-open:rotate-45 group-open:bg-neutral-950 group-open:text-white">+</span>
              </span>
            </summary>
            <p class="mt-3 text-sm leading-6 text-neutral-600">{faq.answer}</p>
          </details>
        ))}
      </div>
    </div>
  ))}
</section>
