---
const { faqs = [] } = Astro.props;
const categories = [...new Set(faqs.map((faq) => faq.category))];
---

<section class="space-y-6">
  {categories.map((category) => (
    <div class="rounded-3xl border border-neutral-200 bg-white p-6 shadow-sm">
      <h2 class="text-xl font-black text-neutral-950">{category}</h2>
      <div class="mt-4 divide-y divide-neutral-100">
        {faqs.filter((faq) => faq.category === category).map((faq) => (
          <details class="group py-4">
            <summary class="focus-ring cursor-pointer list-none font-semibold text-neutral-950">
              <span class="inline-flex w-full items-center justify-between gap-4">
                {faq.question}
                <span class="text-neutral-500 group-open:rotate-45">+</span>
              </span>
            </summary>
            <p class="mt-3 max-w-3xl text-sm leading-6 text-neutral-600">{faq.answer}</p>
            <p class="mt-2 text-xs text-neutral-500">Risk level: {faq.riskLevel}</p>
          </details>
        ))}
      </div>
    </div>
  ))}
</section>
