---
const { faqs = [] } = Astro.props;
const categories = [...new Set(faqs.map((faq) => faq.category))];
---

<section class="space-y-5">
  {categories.map((category) => (
    <div class="rounded-[1.75rem] border border-neutral-200 bg-white p-6 shadow-sm">
      <h2 class="text-2xl font-black text-neutral-950">{category}</h2>
      <div class="mt-4 divide-y divide-neutral-100">
        {faqs.filter((faq) => faq.category === category).map((faq) => (
          <details class="group py-4">
            <summary class="focus-ring cursor-pointer list-none rounded-xl font-bold text-neutral-950">
              <span class="inline-flex w-full items-center justify-between gap-4">
                <span>{faq.question}</span>
                <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-neutral-100 text-neutral-600 transition group-open:rotate-45 group-open:bg-neutral-950 group-open:text-white">+</span>
              </span>
            </summary>
            <p class="mt-4 max-w-3xl text-sm leading-6 text-neutral-600">{faq.answer}</p>
            <p class="mt-3 inline-flex rounded-full bg-neutral-100 px-3 py-1 text-xs font-semibold text-neutral-500">Risk level: {faq.riskLevel}</p>
          </details>
        ))}
      </div>
    </div>
  ))}
</section>
