---
import { resolveLink } from "../utils/resolveLink.js";

const { faqs = [] } = Astro.props;
const categories = [...new Set(faqs.map((faq) => faq.category))];
---

<section class="space-y-6">
  {categories.map((category) => (
    <div class="rounded-3xl border border-neutral-200 bg-white p-6 shadow-sm">
      <h2 class="text-xl font-black text-neutral-950">{category}</h2>
      <div class="mt-4 divide-y divide-neutral-100">
        {faqs.filter((faq) => faq.category === category).map((faq) => (
          <details id={faq.id} class="group scroll-mt-24 py-4">
            <summary class="focus-ring cursor-pointer list-none font-semibold text-neutral-950">
              <span class="inline-flex w-full items-center justify-between gap-4">
                {faq.question}
                <span class="text-neutral-500 transition group-open:rotate-45">+</span>
              </span>
            </summary>
            <div class="mt-3 max-w-3xl text-sm leading-6 text-neutral-600">
              <p>{faq.answer}</p>
              {faq.relatedLinks?.length > 0 && (
                <div class="mt-4 flex flex-wrap gap-2">
                  {faq.relatedLinks.map((link) => (
                    <a
                      class="rounded-full border border-neutral-200 bg-neutral-50 px-3 py-1.5 text-xs font-black text-neutral-800 hover:bg-[#cfb87c]"
                      href={resolveLink(link.href)}
                    >
                      {link.label}
                    </a>
                  ))}
                </div>
              )}
            </div>
          </details>
        ))}
      </div>
    </div>
  ))}
</section>
