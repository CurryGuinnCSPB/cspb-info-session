---
const { panel } = Astro.props;
---

<article class="rounded-[1.75rem] border border-neutral-200 bg-white p-6 shadow-sm">
  <div class="flex items-start justify-between gap-4">
    <div>
      <p class="text-xs font-black uppercase tracking-[0.18em] text-[#8b6f24]">Outcomes placeholder</p>
      <h2 class="mt-2 text-2xl font-black text-neutral-950">{panel.title}</h2>
    </div>
    <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-neutral-950 text-sm font-black text-[#cfb87c]">↗</div>
  </div>
  <p class="mt-4 text-sm leading-6 text-neutral-600">{panel.description}</p>

  <div class="mt-6 space-y-4">
    {panel.items.map((item) => (
      <div>
        <div class="mb-2 flex items-center justify-between gap-3 text-sm">
          <span class="font-bold text-neutral-800">{item.label}</span>
          <span class="font-black text-neutral-950">{item.percent}%</span>
        </div>
        <div class="h-3 overflow-hidden rounded-full bg-neutral-100">
          <div class="h-full rounded-full bg-[#cfb87c]" style={`width: ${item.percent}%`}></div>
        </div>
      </div>
    ))}
  </div>

  <p class="mt-5 rounded-2xl bg-neutral-50 p-4 text-xs leading-5 text-neutral-500">
    Mock data for layout only. Replace with approved outcomes data and a public methodology note.
  </p>
</article>
