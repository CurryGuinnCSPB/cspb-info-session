---
const {
  title = "Video placeholder",
  duration = "2–4 minutes",
  label = "Video module"
} = Astro.props;
---

<section class="rounded-3xl border border-neutral-200 bg-neutral-950 p-6 text-white shadow-sm" aria-label={label}>
  <div class="flex min-h-56 flex-col items-center justify-center rounded-2xl border border-white/15 bg-white/5 p-8 text-center">
    <div class="mb-5 flex h-16 w-16 items-center justify-center rounded-full bg-yellow-500 text-2xl text-neutral-950 shadow">
      ▶
    </div>
    <h2 class="text-xl font-bold">{title}</h2>
    <p class="mt-2 text-sm text-neutral-300">Placeholder video · Target length: {duration}</p>
    <p class="mt-4 max-w-md text-sm text-neutral-400">
      Production videos should include captions and transcripts. Exact dates, tuition, and deadlines should live in controlled web text rather than video narration.
    </p>
  </div>
</section>
