---
const {
  title = "Video placeholder",
  duration = "2–4 minutes",
  label = "Video module",
  compact = false
} = Astro.props;
---

<section class={`relative overflow-hidden rounded-[1.5rem] border border-white/10 bg-neutral-950 text-white shadow-xl ${compact ? "p-3" : "p-5"}`} aria-label={label}>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_20%,rgba(207,184,124,0.24),transparent_20rem),radial-gradient(circle_at_80%_80%,rgba(52,85,111,0.24),transparent_20rem)]"></div>

  <div class={`relative flex flex-col items-center justify-center rounded-[1.25rem] border border-white/15 bg-white/7 p-6 text-center ${compact ? "min-h-56" : "min-h-64"}`}>
    <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-[#cfb87c] text-xl text-neutral-950 shadow-xl shadow-[#cfb87c]/20">
      ▶
    </div>
    <p class="text-xs font-black uppercase tracking-[0.2em] text-[#cfb87c]">Video placeholder</p>
    <h2 class="mt-2 text-xl font-black leading-tight">{title}</h2>
    <p class="mt-2 text-sm text-neutral-300">Target length: {duration}</p>
    <p class="mt-3 max-w-sm text-xs leading-5 text-neutral-400">
      Captions and transcripts required for production.
    </p>
  </div>
</section>
