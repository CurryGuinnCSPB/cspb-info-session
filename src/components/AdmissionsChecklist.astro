---
import CTAButton from "./CTAButton.astro";
const { admissions } = Astro.props;
---

<section class="space-y-6">
  <div class="grid gap-5 lg:grid-cols-2">
    {admissions.requirements.map((item) => (
      <article class="rounded-[1.75rem] border border-neutral-200 bg-white p-6 shadow-sm">
        <p class="text-xs font-black uppercase tracking-[0.18em] text-[#8b6f24]">Requirement</p>
        <h2 class="mt-2 text-2xl font-black text-neutral-950">{item.title}</h2>
        <p class="mt-3 text-sm leading-6 text-neutral-600">{item.body}</p>
      </article>
    ))}
  </div>

  <article class="rounded-[1.75rem] border border-neutral-200 bg-white p-6 shadow-sm">
    <div class="grid gap-6 lg:grid-cols-[1fr_320px]">
      <div>
        <p class="text-xs font-black uppercase tracking-[0.18em] text-[#8b6f24]">Application checklist</p>
        <h2 class="mt-2 text-3xl font-black text-neutral-950">Before you apply</h2>
        <ul class="mt-5 grid gap-3">
          {admissions.checklist.map((item) => (
            <li class="flex gap-3 rounded-2xl bg-neutral-50 p-4 text-sm leading-6 text-neutral-700">
              <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#cfb87c] text-xs font-black text-neutral-950">✓</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <aside class="rounded-[1.5rem] bg-neutral-950 p-6 text-white">
        <p class="text-sm font-black text-[#cfb87c]">Next step</p>
        <h3 class="mt-2 text-2xl font-black">Check the official admissions page.</h3>
        <p class="mt-3 text-sm leading-6 text-neutral-300">
          This mockup summarizes current deck content. The production site should link prospects to the official application details.
        </p>
        <div class="mt-5">
          <CTAButton href="admissions" label="Official admissions page" variant="gold" />
        </div>
      </aside>
    </div>
  </article>
</section>
