---
import CTAButton from "./CTAButton.astro";
---

<section class="rounded-3xl bg-neutral-950 p-8 text-white shadow-sm">
  <div class="grid gap-6 lg:grid-cols-[1fr_auto] lg:items-center">
    <div>
      <p class="text-sm font-bold uppercase tracking-wide text-yellow-400">Next steps</p>
      <h2 class="mt-2 text-2xl font-black tracking-tight">Ready to keep going?</h2>
      <p class="mt-3 max-w-2xl text-neutral-300">
        Apply, schedule an appointment, email the CSPB team, or return to the FAQ if you still have questions.
      </p>
    </div>
    <div class="flex flex-wrap gap-3">
      <CTAButton href="apply" label="Apply" variant="gold" dataCta="apply" />
      <CTAButton href="scheduleAppointment" label="Schedule appointment" variant="secondary" dataCta="schedule_appointment" />
      <CTAButton href="contactEmail" label="Email CSPB" variant="secondary" dataCta="email_cspb" />
    </div>
  </div>
</section>
