---
import CTAButton from "./CTAButton.astro";
---

<section class="relative overflow-hidden rounded-[2rem] bg-neutral-950 p-8 text-white shadow-xl lg:p-10">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_10%_20%,rgba(207,184,124,0.22),transparent_24rem),radial-gradient(circle_at_90%_70%,rgba(52,85,111,0.24),transparent_26rem)]"></div>
  <div class="relative grid gap-8 lg:grid-cols-[1fr_auto] lg:items-center">
    <div>
      <p class="text-sm font-black uppercase tracking-[0.2em] text-[#cfb87c]">Next steps</p>
      <h2 class="mt-3 text-3xl font-black tracking-tight md:text-4xl">Ready to keep going?</h2>
      <p class="mt-4 max-w-2xl text-base leading-7 text-neutral-300">
        Apply, schedule an appointment, email the CSPB team, or use the FAQ to clarify your next question.
      </p>
    </div>
    <div class="flex flex-wrap gap-3 lg:justify-end">
      <CTAButton href="apply" label="Apply" variant="gold" dataCta="apply" />
      <CTAButton href="scheduleAppointment" label="Schedule appointment" variant="secondary" dataCta="schedule_appointment" />
      <CTAButton href="contactEmail" label="Email CSPB" variant="secondary" dataCta="email_cspb" />
    </div>
  </div>
</section>
