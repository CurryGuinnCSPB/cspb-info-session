---
import links from "../data/links.json";
---

<footer class="mx-auto mt-12 w-full max-w-[1500px] px-5 pb-8 text-sm text-neutral-600 lg:px-10">
  <div class="rounded-[1.5rem] border border-neutral-200 bg-white/75 p-6 shadow-sm">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
      <p>
        CSPB self-guided info session mockup. Information is provisional and should be verified before production.
      </p>
      <div class="flex flex-wrap gap-4">
        <a class="font-black text-neutral-900" href={links.contactEmail}>Email CSPB</a>
        <a class="font-black text-neutral-900" href={links.apply}>Apply</a>
        <a class="font-black text-neutral-900" href={links.admissions}>Admissions</a>
      </div>
    </div>
  </div>
</footer>
