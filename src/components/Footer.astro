---
import links from "../data/links.json";
---

<footer class="mt-12 border-t border-neutral-200 px-6 py-8 text-sm text-neutral-600 lg:px-10">
  <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
    <p>
      CSPB self-guided info session mockup. Information is provisional and should be verified before production.
    </p>
    <div class="flex flex-wrap gap-4">
      <a class="font-semibold text-neutral-900" href={links.contactEmail}>Email CSPB</a>
      <a class="font-semibold text-neutral-900" href={links.apply}>Apply</a>
      <a class="font-semibold text-neutral-900" href={links.admissions}>Admissions</a>
    </div>
  </div>
</footer>
